{
    "source": {
        "include": [
            "src"
        ],
        "includePattern": ".+\\.(js|jsx)$",
        "exclude": [
            "node_modules",
            "dist",
            "docs",
            "coverage"
        ],
        "excludePattern": "(^|\\/|\\\\)_"
    },
    "opts": {
        "destination": "./docs",
        "recurse": true,
        "readme": "./README.md",
        "template": "./node_modules/docdash"
    },
    "plugins": [
        "plugins/markdown"
    ],
    "templates": {
        "default": {
            "includeDate": false,
            "outputSourceFiles": true,
            "useLongnameInNav": true
        }
    },
    "docdash": {
        "static": false,
        "sort": true,
        "collapse": false,
        "search": false,
        "typedefs": true,
        "removeQuotes": "none",
        "commonNav": false,
        "sectionOrder": [
            "Classes",
            "Modules",
            "Namespaces",
            "Mixins",
            "Tutorials",
            "Interfaces",
            "Global"
        ],
        "menu": {
            "Github repo": {
                "href": "https://github.com/PetrH630/HobbyHokej-demo",
                "target": "_blank",
                "class": "menu-item",
                "id": "repository_link"
            }
        }
    },
    "markdown": {
        "idInHeadings": true
    }
}