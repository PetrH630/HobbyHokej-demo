@startuml
skinparam linetype ortho
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title User services - třídní diagram

interface AppUserService {
  + register(dto: RegisterUserDTO) : void
  + activateUser(token: String) : boolean
  + activateUserByAdmin(id: Long) : void
  + updateUser(email: String, dto: AppUserDTO) : void
  + getCurrentUser(email: String) : AppUserDTO
  + getAllUsers() : List<AppUserDTO>
  + changePassword(email: String, oldPassword: String, newPassword: String, newPasswordConfirm: String) : void
  + resetPassword(userId: Long) : void
  + deactivateUserByAdmin(id: Long) : void
  + getUserById(id: Long) : AppUserDTO
  + requestForgottenPasswordReset(email: String) : void
  + getForgottenPasswordResetEmail(token: String) : String
  + forgottenPasswordReset(dto: ForgottenPasswordResetDTO) : void
  + onSuccessfulLogin(email: String) : void
}

class AppUserServiceImpl {
  - userRepository : AppUserRepository
  - passwordEncoder : PasswordEncoder
  - appUserMapper : AppUserMapper
  - emailService : EmailService
  - tokenRepository : EmailVerificationTokenRepository
  - appUserSettingsService : AppUserSettingsService
  - notificationService : NotificationService
  - forgottenPasswordResetTokenRepository : ForgottenPasswordResetTokenRepository
  - demoModeGuard : DemoModeGuard
  - clock : Clock
}

interface AppUserSettingsService {
  + getSettingsForUser(userEmail: String) : AppUserSettingsDTO
  + updateSettingsForUser(userEmail: String, dto: AppUserSettingsDTO) : AppUserSettingsDTO
  + createDefaultSettingsForUser(user: AppUserEntity) : AppUserSettingsEntity
}

class AppUserSettingsServiceImpl {
  - appUserRepository : AppUserRepository
  - appUserSettingsRepository : AppUserSettingsRepository
  - mapper : AppUserSettingsMapper
}

interface AppUserHistoryService {
  + getHistoryForUser(email: String) : List<AppUserHistoryDTO>
  + getHistoryForUser(id: Long) : List<AppUserHistoryDTO>
}

class AppUserHistoryServiceImpl {
  - repository : AppUserHistoryRepository
  - mapper : AppUserHistoryMapper
}

class AppUserRepository
class AppUserSettingsRepository
class AppUserHistoryRepository
class EmailVerificationTokenRepository
class ForgottenPasswordResetTokenRepository
class PasswordEncoder
class AppUserMapper
class AppUserSettingsMapper
class AppUserHistoryMapper
class EmailService
class NotificationService
class DemoModeGuard
class Clock

AppUserServiceImpl ..|> AppUserService
AppUserSettingsServiceImpl ..|> AppUserSettingsService
AppUserHistoryServiceImpl ..|> AppUserHistoryService

AppUserServiceImpl --> AppUserRepository
AppUserServiceImpl --> PasswordEncoder
AppUserServiceImpl --> AppUserMapper
AppUserServiceImpl --> EmailService
AppUserServiceImpl --> EmailVerificationTokenRepository
AppUserServiceImpl --> AppUserSettingsService
AppUserServiceImpl --> NotificationService
AppUserServiceImpl --> ForgottenPasswordResetTokenRepository
AppUserServiceImpl --> DemoModeGuard
AppUserServiceImpl --> Clock

AppUserSettingsServiceImpl --> AppUserRepository
AppUserSettingsServiceImpl --> AppUserSettingsRepository
AppUserSettingsServiceImpl --> AppUserSettingsMapper

AppUserHistoryServiceImpl --> AppUserHistoryRepository
AppUserHistoryServiceImpl --> AppUserHistoryMapper
@enduml
