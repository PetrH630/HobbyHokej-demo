@startuml
skinparam shadowing false

title Sequence - forgotten password reset

actor Controller
participant "AppUserServiceImpl" as UserService
participant "AppUserRepository" as UserRepo
participant "ForgottenPasswordResetTokenRepository" as ResetRepo
participant "EmailService" as Email
participant "PasswordEncoder" as Encoder

Controller -> UserService : requestForgottenPasswordReset(email)
UserService -> UserRepo : findByEmail(email)
UserRepo --> UserService : user / silently ignore
alt user exists
  UserService -> ResetRepo : save(reset token)
  UserService -> Email : send reset link
end

Controller -> UserService : forgottenPasswordReset(dto)
UserService -> ResetRepo : findByToken(dto.token)
ResetRepo --> UserService : reset token / exception
UserService -> Encoder : encode(dto.newPassword)
Encoder --> UserService : hashed password
UserService -> UserRepo : save(updated user)
UserService --> Controller : ok
@enduml
