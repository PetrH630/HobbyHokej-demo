@startuml
skinparam linetype ortho
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title PlayerStatsService - výpočet statistik hráče

interface PlayerStatsService {
  + getPlayerStats(playerId: Long) : PlayerStatsDTO
}

class PlayerStatsServiceImpl {
  - playerRepository : PlayerRepository
  - matchRepository : MatchRepository
  - currentSeasonService : CurrentSeasonService
  - seasonService : SeasonService
  - playerInactivityPeriodService : PlayerInactivityPeriodService
  - matchRegistrationService : MatchRegistrationService
  + getPlayerStats(playerId: Long) : PlayerStatsDTO
  - findPastMatchesForCurrentSeason() : List<MatchEntity>
  - getPlayerOrThrow(playerId: Long) : PlayerEntity
  - getCurrentSeasonIdOrActive() : Long
  - isPlayerActiveForMatch(player: PlayerEntity, dateTime: LocalDateTime) : boolean
}

class PlayerRepository
class MatchRepository
class CurrentSeasonService
class SeasonService
interface PlayerInactivityPeriodService
class MatchRegistrationService
class PlayerEntity
class MatchEntity
class MatchRegistrationDTO
class PlayerStatsDTO
class PlayerMatchResultDTO
class PlayerMatchStatus <<enum>>
class MatchStatus <<enum>>
class MatchResult <<enum>>
class Team <<enum>>
class MatchScore
class PlayerNotFoundException <<exception>>
class LocalDateTime

PlayerStatsServiceImpl ..|> PlayerStatsService
PlayerStatsServiceImpl --> PlayerRepository : načtení hráče
PlayerStatsServiceImpl --> MatchRepository : odehrané zápasy sezóny
PlayerStatsServiceImpl --> CurrentSeasonService : current season id
PlayerStatsServiceImpl --> SeasonService : fallback na aktivní sezónu
PlayerStatsServiceImpl --> PlayerInactivityPeriodService : filtr aktivity hráče
PlayerStatsServiceImpl --> MatchRegistrationService : registrace na zápasy

PlayerStatsServiceImpl ..> PlayerEntity
PlayerStatsServiceImpl ..> MatchEntity
PlayerStatsServiceImpl ..> MatchRegistrationDTO
PlayerStatsServiceImpl ..> PlayerStatsDTO
PlayerStatsServiceImpl ..> PlayerMatchResultDTO
PlayerStatsServiceImpl ..> PlayerMatchStatus
PlayerStatsServiceImpl ..> MatchStatus
PlayerStatsServiceImpl ..> MatchResult
PlayerStatsServiceImpl ..> Team
PlayerStatsServiceImpl ..> MatchScore
PlayerStatsServiceImpl ..> PlayerNotFoundException

note right of PlayerStatsServiceImpl
Nejvíce integrační service v balíčku.
Skládá data přes více modulů a převádí je
na agregovaný statistický výstup pro hráče.
end note
@enduml
