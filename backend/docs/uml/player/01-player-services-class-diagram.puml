skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title Player services - třídní diagram

interface PlayerService {
  + getAllPlayers() : List<PlayerDTO>
  + getPlayerById(id: Long) : PlayerDTO
  + createPlayer(player: PlayerDTO) : PlayerDTO
  + createPlayerForUser(dto: PlayerDTO, userEmail: String) : PlayerDTO
  + updatePlayer(id: Long, player: PlayerDTO) : PlayerDTO
  + deletePlayer(id: Long) : SuccessResponseDTO
  + getPlayersByUser(email: String) : List<PlayerDTO>
  + approvePlayer(id: Long) : SuccessResponseDTO
  + rejectPlayer(id: Long) : SuccessResponseDTO
  + setCurrentPlayerForUser(userEmail: String, playerId: Long) : SuccessResponseDTO
  + autoSelectCurrentPlayerForUser(userEmail: String) : SuccessResponseDTO
  + changePlayerUser(id: Long, newUserId: Long) : void
}

class PlayerServiceImpl {
  - playerCommandService : PlayerCommandService
  - playerQueryService : PlayerQueryService
  + createPlayer(dto: PlayerDTO) : PlayerDTO
  + createPlayerForUser(dto: PlayerDTO, userEmail: String) : PlayerDTO
  + updatePlayer(id: Long, dto: PlayerDTO) : PlayerDTO
  + deletePlayer(id: Long) : SuccessResponseDTO
  + approvePlayer(id: Long) : SuccessResponseDTO
  + rejectPlayer(id: Long) : SuccessResponseDTO
  + changePlayerUser(id: Long, newUserId: Long) : void
  + getAllPlayers() : List<PlayerDTO>
  + getPlayerById(id: Long) : PlayerDTO
  + getPlayersByUser(email: String) : List<PlayerDTO>
  + setCurrentPlayerForUser(userEmail: String, playerId: Long) : SuccessResponseDTO
  + autoSelectCurrentPlayerForUser(userEmail: String) : SuccessResponseDTO
}

interface PlayerCommandService {
  + createPlayer(dto: PlayerDTO) : PlayerDTO
  + createPlayerForUser(dto: PlayerDTO, userEmail: String) : PlayerDTO
  + updatePlayer(id: Long, dto: PlayerDTO) : PlayerDTO
  + deletePlayer(id: Long) : SuccessResponseDTO
  + approvePlayer(id: Long) : SuccessResponseDTO
  + rejectPlayer(id: Long) : SuccessResponseDTO
  + changePlayerUser(id: Long, newUserId: Long) : void
  + setCurrentPlayerForUser(userEmail: String, playerId: Long) : SuccessResponseDTO
  + autoSelectCurrentPlayerForUser(userEmail: String) : SuccessResponseDTO
}

class PlayerCommandServiceImpl {
  - playerRepository : PlayerRepository
  - playerMapper : PlayerMapper
  - appUserRepository : AppUserRepository
  - notificationService : NotificationService
  - currentPlayerService : CurrentPlayerService
  - appUserSettingsService : AppUserSettingsService
  - playerSettingsService : PlayerSettingsService
}

interface PlayerQueryService {
  + getAllPlayers() : List<PlayerDTO>
  + getPlayerById(id: Long) : PlayerDTO
  + getPlayersByUser(email: String) : List<PlayerDTO>
}

class PlayerQueryServiceImpl {
  - playerRepository : PlayerRepository
  - playerMapper : PlayerMapper
}

interface CurrentPlayerService {
  + getCurrentPlayerId() : Long
  + setCurrentPlayerId(playerId: Long) : void
  + requireCurrentPlayer() : void
  + clear() : void
}

class CurrentPlayerServiceImpl {
  - session : HttpSession
  - playerRepository : PlayerRepository
  - findPlayerOrThrow(playerId: Long) : PlayerEntity
  - validatePlayerSelectable(player: PlayerEntity) : void
}

interface PlayerSettingsService {
  + getSettingsForPlayer(playerId: Long) : PlayerSettingsDTO
  + updateSettingsForPlayer(playerId: Long, dto: PlayerSettingsDTO) : PlayerSettingsDTO
  + createDefaultSettingsForPlayer(player: PlayerEntity) : PlayerSettingsEntity
}

class PlayerSettingsServiceImpl {
  - playerRepository : PlayerRepository
  - playerSettingsRepository : PlayerSettingsRepository
  - mapper : PlayerSettingsMapper
}

interface PlayerInactivityPeriodService {
  + getAll() : List<PlayerInactivityPeriodDTO>
  + getById(id: Long) : PlayerInactivityPeriodDTO
  + getByPlayer(playerId: Long) : List<PlayerInactivityPeriodDTO>
  + create(dto: PlayerInactivityPeriodDTO) : PlayerInactivityPeriodDTO
  + update(id: Long, dto: PlayerInactivityPeriodDTO) : PlayerInactivityPeriodDTO
  + delete(id: Long) : void
  + isActive(player: PlayerEntity, dateTime: LocalDateTime) : boolean
}

class PlayerInactivityPeriodServiceImpl {
  - inactivityRepository : PlayerInactivityPeriodRepository
  - playerRepository : PlayerRepository
  - mapper : PlayerInactivityPeriodMapper
}

interface PlayerHistoryService {
  + getHistoryForPlayer(playerId: Long) : List<PlayerHistoryDTO>
}

class PlayerHistoryServiceImpl {
  - repository : PlayerHistoryRepository
  - mapper : PlayerHistoryMapper
}

interface PlayerStatsService {
  + getPlayerStats(playerId: Long) : PlayerStatsDTO
}

class PlayerStatsServiceImpl {
  - playerRepository : PlayerRepository
  - matchRepository : MatchRepository
  - currentSeasonService : CurrentSeasonService
  - seasonService : SeasonService
  - playerInactivityPeriodService : PlayerInactivityPeriodService
  - matchRegistrationService : MatchRegistrationService
}

