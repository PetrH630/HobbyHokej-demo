@startuml
skinparam linetype ortho
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title Season services - třídní diagram

interface SeasonService {
  + createSeason(seasonDTO: SeasonDTO) : SeasonDTO
  + updateSeason(id: Long, seasonDTO: SeasonDTO) : SeasonDTO
  + getActiveSeason() : SeasonEntity
  + getActiveSeasonOrNull() : SeasonDTO
  + getSeasonById(id: Long) : SeasonDTO
  + getAllSeasons() : List<SeasonDTO>
  + setActiveSeason(seasonId: Long) : void
}
class SeasonServiceImpl {
  - seasonRepository : SeasonRepository
  - mapper : SeasonMapper
  - appUserRepository : AppUserRepository
}

interface CurrentSeasonService {
  + getCurrentSeasonIdOrDefault() : Long
  + setCurrentSeasonId(seasonId: Long) : void
  + clearCurrentSeason() : void
}
class CurrentSeasonServiceImpl {
  - session : HttpSession
  - seasonService : SeasonService
}

interface SeasonHistoryService {
  + getHistoryForSeason(seasonId: Long) : List<SeasonHistoryDTO>
}
class SeasonHistoryServiceImpl {
  - repository : SeasonHistoryRepository
  - mapper : SeasonHistoryMapper
}

class SeasonRepository
class SeasonHistoryRepository
class SeasonMapper
class SeasonHistoryMapper
class AppUserRepository
interface HttpSession

SeasonServiceImpl ..|> SeasonService
CurrentSeasonServiceImpl ..|> CurrentSeasonService
SeasonHistoryServiceImpl ..|> SeasonHistoryService
@enduml
