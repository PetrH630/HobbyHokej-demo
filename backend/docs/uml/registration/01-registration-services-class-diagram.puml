@startuml
skinparam linetype ortho
skinparam shadowing false
skinparam classAttributeIconSize 0
left to right direction

title Registration services - třídní diagram

interface MatchRegistrationService {
  + upsertRegistration(playerId: Long, request: MatchRegistrationRequest) : MatchRegistrationDTO
  + markNoExcused(matchId: Long, playerId: Long, adminNote: String) : MatchRegistrationDTO
  + cancelNoExcused(matchId: Long, playerId: Long, excuseReason: ExcuseReason, excuseNote: String) : MatchRegistrationDTO
  + changeRegistrationTeam(playerId: Long, matchId: Long) : MatchRegistrationDTO
  + changeRegistrationPosition(playerId: Long, matchId: Long, positionInMatch: PlayerPosition) : MatchRegistrationDTO
  + updateStatus(matchId: Long, playerId: Long, status: PlayerMatchStatus) : MatchRegistrationDTO
  + recalcStatusesForMatch(matchId: Long) : void
  + promoteReservedCandidatesForCapacityIncrease(matchId: Long, freedTeam: Team, freedPosition: PlayerPosition, slotsCount: int) : void
  + sendSmsToRegisteredPlayers(matchId: Long) : void
  + getRegistrationsForMatch(matchId: Long) : List<MatchRegistrationDTO>
  + getRegistrationsForMatches(matchIds: List<Long>) : List<MatchRegistrationDTO>
  + getAllRegistrations() : List<MatchRegistrationDTO>
  + getRegistrationsForPlayer(playerId: Long) : List<MatchRegistrationDTO>
  + getNoResponsePlayers(matchId: Long) : List<PlayerDTO>
}

class MatchRegistrationServiceImpl {
  - commandService : MatchRegistrationCommandService
  - matchRegistrationQueryService : MatchRegistrationQueryService
}

interface MatchRegistrationCommandService
class MatchRegistrationCommandServiceImpl {
  - registrationRepository : MatchRegistrationRepository
  - matchRepository : MatchRepository
  - playerRepository : PlayerRepository
  - matchRegistrationMapper : MatchRegistrationMapper
  - smsService : SmsService
  - smsMessageBuilder : SmsMessageBuilder
  - notificationService : NotificationService
  - matchAllocationEngine : MatchAllocationEngine
}

interface MatchRegistrationQueryService
class MatchRegistrationQueryServiceImpl {
  - registrationRepository : MatchRegistrationRepository
  - matchRepository : MatchRepository
  - playerRepository : PlayerRepository
  - matchRegistrationMapper : MatchRegistrationMapper
  - playerMapper : PlayerMapper
  - seasonService : SeasonService
  - currentSeasonService : CurrentSeasonService
}

interface MatchRegistrationHistoryService
class MatchRegistrationHistoryServiceImpl {
  - historyRepository : MatchRegistrationHistoryRepository
  - historyMapper : MatchRegistrationHistoryMapper
  - currentPlayerService : CurrentPlayerService
  - matchRepository : MatchRepository
}

class MatchRegistrationRepository
class MatchRegistrationHistoryRepository
class MatchRepository
class PlayerRepository
class MatchRegistrationMapper
class MatchRegistrationHistoryMapper
class PlayerMapper
class NotificationService
class SmsService
class SmsMessageBuilder
class MatchAllocationEngine
class CurrentPlayerService
class SeasonService
class CurrentSeasonService

MatchRegistrationServiceImpl ..|> MatchRegistrationService
MatchRegistrationCommandServiceImpl ..|> MatchRegistrationCommandService
MatchRegistrationQueryServiceImpl ..|> MatchRegistrationQueryService
MatchRegistrationHistoryServiceImpl ..|> MatchRegistrationHistoryService

MatchRegistrationServiceImpl --> MatchRegistrationCommandService
MatchRegistrationServiceImpl --> MatchRegistrationQueryService
@enduml
